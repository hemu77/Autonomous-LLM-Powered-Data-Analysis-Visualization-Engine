# Required for existing provider models in the project
CYVERSE_API_KEY=replace_me

# Required for complex planning and critic passes (hybrid routing)
OPENAI_API_KEY=replace_me

# Optional override for standard provider base URL
CYVERSE_API_BASE=https://llm-api.cyverse.ai/v1

# Optional OpenAI base URL override (usually not needed)
OPENAI_API_BASE=https://api.openai.com/v1
